{
  "displayName": "Syrabit · Chat p95 latency (main path) > 8s",
  "documentation": {
    "content": "Chat total wall-clock latency (`syrabit.chat.total_ms`) p95 over a 10-minute rolling window has exceeded 8000ms for the `main` chat path (excludes cache / instant / early-cache short paths). Investigate provider hedge (`syrabit.chat.provider`), retrieval phase (`chat.retrieval` span), and LLM call phase (`chat.llm_call` span) in Cloud Trace. Auto-closes 5 minutes after returning healthy.",
    "mimeType": "text/markdown",
    "subject": "Syrabit chat p95 latency degraded"
  },
  "userLabels": {
    "service": "syrabit-backend",
    "owner": "syrabit-platform",
    "severity": "warning"
  },
  "combiner": "OR",
  "enabled": true,
  "conditions": [
    {
      "displayName": "chat.total_ms p95 > 8s for 10m (main path)",
      "conditionThreshold": {
        "filter": "metric.type=\"custom.googleapis.com/opentelemetry/syrabit.chat.total_ms\" AND resource.type=\"generic_task\" AND metric.label.\"syrabit_chat_path\"=\"main\"",
        "aggregations": [
          {
            "alignmentPeriod": "60s",
            "perSeriesAligner": "ALIGN_PERCENTILE_95",
            "crossSeriesReducer": "REDUCE_PERCENTILE_95",
            "groupByFields": [
              "metric.label.\"syrabit_chat_path\""
            ]
          }
        ],
        "comparison": "COMPARISON_GT",
        "thresholdValue": 8000.0,
        "duration": "600s",
        "trigger": {
          "count": 1
        }
      }
    }
  ],
  "alertStrategy": {
    "autoClose": "300s",
    "notificationRateLimit": {
      "period": "300s"
    }
  },
  "severity": "WARNING"
}
