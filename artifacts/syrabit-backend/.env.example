# ─── Syrabit.ai Backend — Environment Variables ───────────────────────────────
# Copy this file to .env and fill in real values before deploying.

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8000
WORKERS=2

# ── Database (MongoDB Atlas) ─────────────────────────────────────────────────
MONGO_URL=mongodb+srv://user:pass@cluster.mongodb.net/?retryWrites=true&w=majority
DB_NAME=syrabit_prod

# ── PostgreSQL (managed — Supabase / Neon / etc.) ────────────────────────────
# config.py reads DATABASE_URL for the PG connection string.
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# ── Redis (Upstash) ─────────────────────────────────────────────────────────
# config.py reads UPSTASH_REDIS_REST_URL / UPSTASH_REDIS_REST_TOKEN (primary)
# and falls back to REDIS_URL if the Upstash vars are empty.
UPSTASH_REDIS_REST_URL=https://your-region.upstash.io
UPSTASH_REDIS_REST_TOKEN=CHANGE_ME

# ── Auth & Security ─────────────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_random_64_char_string
ADMIN_JWT_SECRET=CHANGE_ME_another_random_64_char_string
SECURE_COOKIES=true
COOKIE_DOMAIN=.syrabit.ai
COOKIE_SAMESITE=none

# ── Admin Accounts ──────────────────────────────────────────────────────────
ADMIN_EMAILS=admin@syrabit.ai
ADMIN_PASSWORDS=CHANGE_ME
ADMIN_NAMES=Admin

# ── CORS / Origins ──────────────────────────────────────────────────────────
CORS_ORIGINS=https://syrabit.ai,https://www.syrabit.ai
PRODUCTION_ORIGINS=https://syrabit.ai,https://www.syrabit.ai,https://api.syrabit.ai
FRONTEND_URL=https://syrabit.ai

# ── Google OAuth ────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── AI Providers (at least one LLM key required) ───────────────────────────
LLM_PROVIDER=groq
LLM_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
GROQ_API_KEY=CHANGE_ME
GROQ_API_KEY_2=
GEMINI_API_KEY=
GEMINI_API_KEY_2=
XAI_API_KEY=
OPENAI_API_KEY=
FIREWORKS_API_KEY=
SARVAM_API_KEY=
SARVAM_API_KEY_2=
CEREBRAS_API_KEY=
EMERGENT_API_KEY=
OPENROUTER_API_KEY=

# ── AWS (Bedrock, optional) ─────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# ── Voyage AI (embeddings) ──────────────────────────────────────────────────
VOYAGE_API_KEY=

# ── Cloudflare ──────────────────────────────────────────────────────────────
CF_ANALYTICS_API_TOKEN=
CF_ZONE_ID=
CF_AI_GATEWAY_ACCOUNT_ID=
CF_AI_GATEWAY_ID=
CF_AI_GATEWAY_CACHE_TTL=3600

# ── Payments — Razorpay ─────────────────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ── Payments — Stripe (optional) ────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Email (Resend) ──────────────────────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=noreply@syrabit.ai

# ── Supabase (legacy, optional) ─────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_ANON_KEY=

# ── Analytics ───────────────────────────────────────────────────────────────
GA4_REFRESH_TOKEN=
IP_HASH_SALT=CHANGE_ME_random_string

# ── Push Notifications (VAPID) ──────────────────────────────────────────────
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CLAIMS_EMAIL=mailto:admin@syrabit.ai
