# ─────────────────────────────────────────────────────────────────────────────
# Syrabit.ai Backend — Environment Variables
# Copy this file to .env and fill in your values before starting the server.
# NEVER commit .env to git — it is listed in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
MONGO_URL=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
DB_NAME=test_database
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Redis / Cache ────────────────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token

# ── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJ...
SUPABASE_ANON_KEY=eyJ...

# ── Security ─────────────────────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_generate_a_long_random_secret
ADMIN_JWT_SECRET=CHANGE_ME_generate_a_different_long_random_secret

# ── Admin Bootstrap ──────────────────────────────────────────────────────────
ADMIN_EMAILS=admin@syrabit.ai
ADMIN_PASSWORDS=change_me_strong_password
ADMIN_NAMES=Admin

# ── Google OAuth ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPx-xxx

# ── CORS / Cookies ───────────────────────────────────────────────────────────
CORS_ORIGINS=https://syrabit.ai,https://www.syrabit.ai,https://api.syrabit.ai
SECURE_COOKIES=true
COOKIE_DOMAIN=.syrabit.ai
FRONTEND_URL=https://syrabit.ai

# ── AI / LLM Providers ──────────────────────────────────────────────────────
GROQ_API_KEY=gsk_xxx
GROQ_API_KEY_2=gsk_xxx
GEMINI_API_KEY=AIza...
CEREBRAS_API_KEY=csk-xxx
FIREWORKS_API_KEY=fw_xxx
SARVAM_API_KEY=xxx
SARVAM_API_KEY_2=xxx
OPENROUTER_API_KEY=sk-or-xxx
EMERGENT_API_KEY=xxx
VOYAGE_API_KEY=pa-xxx

# ── Email ────────────────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxx
EMAIL_FROM=noreply@syrabit.ai

# ── Payments ─────────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_live_xxx
RAZORPAY_KEY_SECRET=xxx
RAZORPAY_WEBHOOK_SECRET=xxx

# ── Edge Worker ──────────────────────────────────────────────────────────────
D1_SYNC_SECRET=your-sync-secret
EDGE_WORKER_URL=https://api.syrabit.ai

# ── Cloudflare (optional) ───────────────────────────────────────────────────
CF_AI_GATEWAY_ACCOUNT_ID=
CF_AI_GATEWAY_ID=
CF_ANALYTICS_API_TOKEN=
CF_ZONE_ID=

# ── Server Tuning ────────────────────────────────────────────────────────────
PORT=8000
GUNICORN_WORKERS=2
GUNICORN_THREADS=2
LOG_LEVEL=warning
LLM_MAX_CONCURRENT=40
