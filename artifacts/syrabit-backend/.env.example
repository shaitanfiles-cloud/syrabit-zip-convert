# ─────────────────────────────────────────────────────────────────────────────
# Syrabit.ai Backend — Environment Variables
# Copy this file to .env and fill in your values before starting the server.
# NEVER commit .env to git — it is listed in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# MongoDB connection string (Atlas or self-hosted)
MONGO_URL=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
# MONGODB_URI=   # alias accepted if MONGO_URL is not set

# MongoDB database name
DB_NAME=syrabit_prod

# Optional: Postgres connection string (Supabase or plain Postgres)
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Security ──────────────────────────────────────────────────────────────────
# Long random strings — generate with: python3 -c "import secrets; print(secrets.token_hex(48))"
JWT_SECRET=CHANGE_ME_generate_a_long_random_secret
ADMIN_JWT_SECRET=CHANGE_ME_generate_a_different_long_random_secret

# ── AI / LLM Provider ─────────────────────────────────────────────────────────
# Set LLM_PROVIDER to one of: sarvam | fireworks | openai | groq | gemini
# Only the key for the chosen provider is required.
LLM_PROVIDER=sarvam
LLM_MODEL=sarvam-m

SARVAM_API_KEY=your_sarvam_api_key_here
OPENAI_API_KEY=
GROQ_API_KEY=
GEMINI_API_KEY=
FIREWORKS_API_KEY=
XAI_API_KEY=

# AWS Bedrock (optional — only if LLM_PROVIDER=bedrock)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# ── Redis / Cache ─────────────────────────────────────────────────────────────
# Upstash Redis (recommended for serverless/Replit)
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token

# Plain Redis URL (used as fallback if Upstash vars are absent)
REDIS_URL=redis://localhost:6379

# ── Email ─────────────────────────────────────────────────────────────────────
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM=noreply@syrabit.ai

# ── Supabase (optional auth/storage) ──────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Payments ──────────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_live_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# ── Admin Bootstrap ───────────────────────────────────────────────────────────
# Comma-separated lists — must be equal length
ADMIN_EMAILS=admin@syrabit.ai
ADMIN_PASSWORDS=change_me_strong_password
ADMIN_NAMES=Admin

# ── CORS / Frontend ───────────────────────────────────────────────────────────
FRONTEND_URL=https://syrabit.ai
# Comma-separated allowed origins (leave * for development, restrict in production)
CORS_ORIGINS=https://syrabit.ai,https://www.syrabit.ai

# ── Server Tuning ─────────────────────────────────────────────────────────────
PORT=8000
GUNICORN_WORKERS=2
GUNICORN_THREADS=2
LOG_LEVEL=warning
LLM_MAX_CONCURRENT=20
LLM_BATCH_WINDOW_MS=15
SECURE_COOKIES=true
