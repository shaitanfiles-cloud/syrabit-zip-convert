# ─────────────────────────────────────────────────────────────────────────────
# Syrabit.ai Backend — Environment Variables
# Copy this file to .env and fill in your values before starting the server.
# NEVER commit .env to git — it is listed in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
MONGO_URL=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
DB_NAME=test_database
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Redis / Cache ────────────────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token

# ── Memorystore-backed AI response cache (Task #609 / #629) ───────────────
# Single Redis URL for the AI response cache. The URL **must** include the
# scheme prefix or startup will fall back to memory-only:
#   rediss://default:<password>@<host>:<port>   ← TLS (Upstash, Memorystore 7+)
#   redis://<user>:<password>@<host>:<port>     ← plain
#
# Where to find it on Upstash: open the database → "Connect to your
# database" tab → choose `redis-cli` or `Node.js (ioredis)` → copy the
# full URL. Do NOT paste the REST API URL (https://...upstash.io) —
# that goes in UPSTASH_REDIS_REST_URL above.
#
# Falls back to UPSTASH_REDIS_REST_URL/TOKEN, then in-memory only.
# Requires the `redis` Python package (already pinned in requirements.txt).
MEMORYSTORE_REDIS_URL=
REDIS_AI_CACHE_NAMESPACE=ai_cache
REDIS_AI_CACHE_TTL=3600
REDIS_CASUAL_CACHE_TTL=300
REDIS_AI_CACHE_MAX_ENTRY_BYTES=65536
REDIS_AI_CACHE_CONNECT_TIMEOUT_MS=200
REDIS_AI_CACHE_OP_TIMEOUT_MS=150

# ── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJ...
SUPABASE_ANON_KEY=eyJ...

# ── Security ─────────────────────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_generate_a_long_random_secret
ADMIN_JWT_SECRET=CHANGE_ME_generate_a_different_long_random_secret

# ── Admin Bootstrap ──────────────────────────────────────────────────────────
ADMIN_EMAILS=admin@syrabit.ai
ADMIN_PASSWORDS=change_me_strong_password
ADMIN_NAMES=Admin

# ── Google OAuth ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── CORS / Cookies ───────────────────────────────────────────────────────────
CORS_ORIGINS=https://syrabit.ai,https://www.syrabit.ai,https://api.syrabit.ai
SECURE_COOKIES=true
COOKIE_DOMAIN=.syrabit.ai
FRONTEND_URL=https://syrabit.ai

# ── AI / LLM Providers ──────────────────────────────────────────────────────
GROQ_API_KEY=gsk_xxx
GROQ_API_KEY_2=gsk_xxx
# GEMINI_API_KEY is OPTIONAL / LEGACY — intentionally NOT shipped as a
# default in this template. Gemini auth is BYOK via the Cloudflare AI
# Gateway binding (Task #666); the user-supplied key is forwarded
# through the AI Gateway request context, not read from a backend env
# var. Setting GEMINI_API_KEY on the backend is only useful as an
# emergency rollback path (see docs/VERTEX_SETUP.md → "Migrating
# Railway → CF AI Gateway BYOK") and otherwise just re-introduces a
# shared secret on the origin without changing chat behaviour.
# Reference: docs/VERTEX_SETUP.md, DEPLOY.md → "Gemini / BYOK".
CEREBRAS_API_KEY=csk-xxx
SARVAM_API_KEY=xxx
SARVAM_API_KEY_2=xxx
OPENROUTER_API_KEY=sk-or-xxx

# ── Vertex AI Gemini Flash chat (Task #607) ─────────────────────────────────
# When VERTEX_PROJECT_ID is set, the user-facing chat can stream through
# Vertex AI Gemini Flash for lowest TTFT. The legacy SLM pool above is
# always preserved as an automatic fallback if Vertex fails before the
# first token reaches the client.
#
# Auth (pick ONE):
#   1. Application Default Credentials (recommended on GCP):
#      set GOOGLE_APPLICATION_CREDENTIALS to a service-account JSON path,
#      OR run on a workload-identity-bound resource.
#   2. Inline JSON blob in env (recommended on Railway / Cloud Run):
#      set VERTEX_SERVICE_ACCOUNT_JSON to the *raw JSON contents* of the
#      service account key (single-line, properly escaped).
#
# The active chat provider is also overridable at runtime via the admin
# panel → API Config → Chat Model. CHAT_DEFAULT_MODEL only applies when
# no admin override has been saved.
VERTEX_PROJECT_ID=
VERTEX_LOCATION=us-central1
VERTEX_GEMINI_MODEL=gemini-2.5-flash
VERTEX_SERVICE_ACCOUNT_JSON=
CHAT_DEFAULT_MODEL=vertex/gemini-flash

# ── Email ────────────────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxx
EMAIL_FROM=noreply@syrabit.ai

# ── Payments ─────────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_live_xxx
RAZORPAY_KEY_SECRET=xxx
RAZORPAY_WEBHOOK_SECRET=xxx

# ── Edge Worker ──────────────────────────────────────────────────────────────
D1_SYNC_SECRET=your-sync-secret
EDGE_WORKER_URL=https://api.syrabit.ai

# Optional preview-tier fan-out (Task #879). When BOTH variables below are
# set on Railway, every D1 sync (CRUD-driven, scheduled, or manual) ALSO
# POSTs the same payload to the preview Worker so the preview D1
# (`syrabit-content-preview`) is auto-populated from prod content. Preview
# failures are logged but never block the prod sync.
#
# The secret MUST match the value bound on the preview Worker via
#   wrangler secret put D1_SYNC_SECRET --env preview
# (Wrangler v4 keeps secrets per-env — the prod value is NOT inherited.)
#
# Leave both empty to disable the fan-out.
EDGE_WORKER_PREVIEW_URL=
D1_SYNC_SECRET_PREVIEW=

# ── Cloud Run origin auth (Task #606) ───────────────────────────────────────
# When the backend runs on Cloud Run behind Cloudflare, the edge worker
# must inject `X-Origin-Auth: <ORIGIN_SHARED_SECRET>` on every backend
# fetch. Requests that arrive without this header (i.e. someone hitting
# the *.run.app URL directly) are rejected with 403. Generate once with:
#   python3 -c 'import secrets;print(secrets.token_urlsafe(48))'
# and bind the SAME value as `BACKEND_ORIGIN_SECRET` on the worker
# (`wrangler secret put BACKEND_ORIGIN_SECRET`). Leave empty on Railway.
ORIGIN_SHARED_SECRET=
ORIGIN_SHARED_SECRET_HEADER=X-Origin-Auth

# ── Cloudflare (optional) ───────────────────────────────────────────────────
CF_AI_GATEWAY_ACCOUNT_ID=
CF_AI_GATEWAY_ID=
CF_ANALYTICS_API_TOKEN=
CF_ZONE_ID=

# ── RAG Retriever Selection (Task #608) ─────────────────────────────────────
# Pick the vector-retrieval backend the syllabus embedder + RAG pipeline
# uses. The admin runtime override (PUT /admin/retriever/config) wins
# over this env var; this is the fallback when no override is set.
#   vectorize  — Cloudflare Vectorize (default; production today)
#   vertex     — Google Vertex AI Vector Search (A/B candidate)
RAG_RETRIEVER=vectorize

# ── Vertex AI Vector Search (only required when RAG_RETRIEVER=vertex
#    OR for running scripts/ingest_vertex_index.py / bench/retriever_bench.py).
#    See docs/VERTEX_RETRIEVER.md for the full setup. ──────────────────────
VERTEX_PROJECT_ID=
VERTEX_LOCATION=us-central1
VERTEX_INDEX_ID=
VERTEX_INDEX_ENDPOINT_ID=
VERTEX_DEPLOYED_INDEX_ID=
# Inline JSON or path to a service-account JSON file with
# roles/aiplatform.user + roles/aiplatform.indexEndpointAdmin.
VERTEX_SERVICE_ACCOUNT=
# Optional: public-domain endpoint URL (set when the IndexEndpoint was
# deployed with --public-endpoint-enabled).
VERTEX_PUBLIC_DOMAIN_ENDPOINT=
VERTEX_DIMENSIONS=1024

# ── Indic / Assamese language purity ────────────────────────────────────────
# Sarvam Indic models occasionally emit stray English fragments inside an
# otherwise-Assamese reply. The leakage detector measures the ratio of
# non-whitelisted Latin characters and acts according to the chosen
# behaviour. Numbers, units, acronyms, proper nouns, code, math and URLs
# are always preserved untouched.
#
# Behaviours:
#   off                  — no sanitisation, just measure (debug only)
#   strip                — delete suspicious Latin runs (legacy, lossy)
#   translate            — call Sarvam /translate on suspicious runs and
#                          splice Assamese back in (DEFAULT — recommended)
#   regenerate           — strip + one-shot LLM retry with a stronger directive
#   translate+regenerate — translate first, then if still leaky also retry
#                          (highest purity, +1 LLM call latency)
ASSAMESE_LEAK_BEHAVIOUR=translate
ASSAMESE_LEAK_THRESHOLD=0.05

# ── Observability — OpenTelemetry distributed tracing (Task #610) ───────────
# Production-only, sampled traces shipped to Google Cloud Trace by default.
# Spans cover the FastAPI request, downstream httpx calls (Vertex, Sarvam,
# Cloudflare AI Gateway), and the chat-stream lifecycle (chat.send →
# chat.first_token → total). Trace IDs flow edge-worker → backend via
# the W3C `traceparent` header so a single chat request is one trace.
#
# Set TRACING_ENABLED=1 in production only. Sample ratio 0.10–0.20 keeps
# Cloud Trace ingest cheap while preserving statistical significance for
# the p95 latency alert.
TRACING_ENABLED=
TRACE_SAMPLE_RATIO=0.1
OTEL_SERVICE_NAME=syrabit-backend
OTEL_EXPORTER=cloud_trace
# Required when OTEL_EXPORTER=cloud_trace. Falls back to GOOGLE_CLOUD_PROJECT
# / VERTEX_PROJECT_ID when blank.
GCP_PROJECT_ID=
# Used only when OTEL_EXPORTER=otlp (e.g. Honeycomb / Tempo / Grafana Cloud).
# OTEL_EXPORTER_OTLP_ENDPOINT=https://api.honeycomb.io
DEPLOYMENT_ENV=production

# ── Server Tuning ────────────────────────────────────────────────────────────
PORT=8000
GUNICORN_WORKERS=2
GUNICORN_THREADS=2
LOG_LEVEL=warning
LLM_MAX_CONCURRENT=40
