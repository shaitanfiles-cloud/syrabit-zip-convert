# ─────────────────────────────────────────────────────────────────────────────
# Syrabit.ai Frontend — Environment Variables
# Copy this file to .env and fill in your values before running the dev server.
# NEVER commit .env to git — it is listed in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# URL of the FastAPI backend (no trailing slash)
# Development: http://localhost:8000
# Production:  https://api.syrabit.ai  (Cloudflare Worker proxies to Replit backend)
VITE_BACKEND_URL=https://api.syrabit.ai

# Google Analytics Measurement ID (optional — leave empty to disable)
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX
