# ─────────────────────────────────────────────────────────────────────────────
# Syrabit.ai Frontend — Environment Variables
# Copy this file to .env and fill in your values before running the dev server.
# NEVER commit .env to git — it is listed in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# Build mode
NODE_ENV=production

# URL of the FastAPI backend (no trailing slash). Default is empty
# (the dev contract). Production builds get the real URL from
# .env.production (`VITE_BACKEND_URL=https://api.syrabit.ai`) — do NOT
# uncomment the production line below for local dev.
#
# WARNING: do NOT set this to https://api.syrabit.ai for local dev.
# The prod origin is behind Cloudflare and returns a 403 "Just a
# moment…" challenge HTML to the Replit preview / localhost, which
# surfaces in the UI as the red "Failed to load library" error state
# on /library. Leave this empty so requests go through the Vite proxy
# in vite.config.js (/api → http://localhost:8000).
#
# IMPORTANT: in this Replit workspace VITE_BACKEND_URL is intentionally
# scoped to the *production* environment ONLY (see Tools → Secrets). Do
# not promote it to the "shared" scope — `shared` leaks into the dev
# workflow's process.env, which Vite reads BEFORE this .env file, so
# the dev frontend would silently start hitting prod and tripping
# Cloudflare. If you ever see /library showing "Failed to load
# library" in the dev preview, check the Secrets pane first.
VITE_BACKEND_URL=
# VITE_BACKEND_URL=https://api.syrabit.ai   # production builds only

# Optional: Cloudflare Worker API URL (no trailing slash, leave empty if not used)
VITE_WORKER_API_URL=

# Cloudflare Web Analytics beacon token (set in index.html or via env var)
# VITE_CF_ANALYTICS_TOKEN=

# Google Analytics 4 measurement ID. MUST be in the format G-XXXXXXXXXX
# (e.g. G-ABC1234567). Anything else (blank, legacy UA-* IDs, raw account
# numeric IDs, etc.) is rejected by vite.config.js → ga4Plugin and gtag
# is simply not loaded — the app keeps working without GA4.
# VITE_GA4_ID=G-XXXXXXXXXX

# ─────────────────────────────────────────────────────────────────────────────
# Firebase Performance Monitoring (Task #610) — production-only RUM.
# Captures Core Web Vitals (LCP, INP, CLS, TTFB, FCP) plus custom chat
# traces (chat_send_first_token, chat_send_total) and page-load metrics.
#
# All five lines must be set together — leave blank to disable Perf
# entirely (the app keeps working with PostHog + GA4 reporters only).
# Sample rate ranges 0.0–1.0; default 0.2 (20%). The session bucket is
# sticky for the page-view so all metrics from one session ship together.
# ─────────────────────────────────────────────────────────────────────────────
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=syrabit.firebaseapp.com
# VITE_FIREBASE_PROJECT_ID=syrabit-prod
# VITE_FIREBASE_STORAGE_BUCKET=syrabit-prod.appspot.com
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_APP_ID=
# VITE_FIREBASE_MEASUREMENT_ID=
# VITE_FIREBASE_PERF_SAMPLE_RATE=0.2

# ─────────────────────────────────────────────────────────────────────────────
# DO NOT set on Cloudflare Pages (these are backend / Worker secrets only):
#   CF_ANALYTICS_API_TOKEN  — backend uses it to read CF Analytics GraphQL
#   CF_ZONE_ID              — backend-only; the frontend never reads it
#   D1_SYNC_SECRET, EDGE_WORKER_URL, SUPABASE_DB_URL, ADMIN_*, etc.
# Setting these as Pages env vars leaks them into frontend build logs.
# ─────────────────────────────────────────────────────────────────────────────
