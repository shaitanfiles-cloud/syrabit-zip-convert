# See https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files for more about ignoring files.

# ── Node.js ───────────────────────────────────────────────────────────────────
node_modules/
dist/
tmp/
out-tsc/
*.tsbuildinfo
.expo
.expo-shared
npm-debug.log
yarn-error.log
testem.log
/typings
coverage/

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
.Python
venv/
.venv/
.venv-prod/
.pythonlibs/
.python-deps/
env/
ENV/
.pytest_cache/
*.pyo
*.pyd

# ── Environment / Secrets ─────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ── Build outputs ─────────────────────────────────────────────────────────────
artifacts/syrabit/dist/
artifacts/syrabit-backend/static/

# ── IDEs and editors ─────────────────────────────────────────────────────────
/.idea
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.cursor/rules/nx-rules.mdc
.github/instructions/nx.instructions.md

# ── OS files ─────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
/.sass-cache
/connect.lock
/libpeerconnection.log

# ── Replit internals (not needed in clone) ────────────────────────────────────
.cache/
.local/
