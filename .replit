modules = ["nodejs-24", "postgresql-16", "python-3.11"]

[[artifacts]]
id = "artifacts/mockup-sandbox"

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"
packages = ["cargo", "libiconv", "libxcrypt", "rustc"]

[userenv]

[userenv.shared]
DB_NAME = "test_database"
CORS_ORIGINS = "http://localhost:5000,http://localhost:3000,http://0.0.0.0:5000,https://90464407-7954-469a-ae00-d16f60f666ea-00-19ag09bq0sa15.pike.replit.dev"
ADMIN_EMAILS = "admin@syrabit.ai"
ADMIN_NAMES = "Administrator"
LLM_PROVIDER = "groq"
LLM_MODEL = "llama-3.3-70b-versatile"
SECURE_COOKIES = "false"
SUPABASE_URL = "https://czeznmqogtwecidhpysa.supabase.co"
UPSTASH_REDIS_REST_URL = "https://tolerant-sawfish-67135.upstash.io"
GOOGLE_OAUTH_CLIENT_ID = "562571664721-d4pji8dnp263qmafctfhdsts09u3h3jc.apps.googleusercontent.com"
VITE_SITE_URL = "https://syrabit.ai"
TRUSTPILOT_BUSINESS_UNIT_ID = "6831bda2e0dd12f40d94de6c"

[userenv.development]

[userenv.production]
