# Syrabit.ai Edge Worker - Environment Variables
# Copy this file to .dev.vars for local development
# DO NOT commit .dev.vars to git (it's gitignored)

# Backend URLs
RUST_CORE_GRPC_URL=https://rust-core.syrabit.ai:50051
RUST_CORE_HTTP_URL=https://rust-core.syrabit.ai
PYTHON_BACKEND_URL=https://workspacemockup-sandbox-production-df37.up.railway.app

# D1 Database (local development only - production uses Cloudflare binding)
# D1_DATABASE is bound via wrangler.toml, not env vars

# Cache Configuration
CACHE_TTL_SECONDS=300
SPECULATIVE_THRESHOLD_MS=100

# Secrets (set via `wrangler secret put` in production)
# D1_SYNC_SECRET=<required-for-sync-endpoints>
# BACKEND_ORIGIN_SECRET=<required-for-cloud-run-backend>
# EDGE_AI_FALLBACK_SECRET=<required-for-workers-ai-fallback>
