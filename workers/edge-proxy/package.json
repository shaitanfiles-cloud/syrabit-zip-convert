{
  "name": "syrabit-edge",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "build": "echo 'syrabit-edge: no build step — wrangler bundles src/index.ts on deploy'",
    "deploy": "wrangler deploy",
    "test": "vitest run",
    "d1:migrate:local": "wrangler d1 migrations apply syrabit-content --local",
    "d1:migrate:remote": "wrangler d1 migrations apply syrabit-content --remote"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260424.1",
    "typescript": "^5.7.0",
    "vitest": "^4.1.4",
    "wrangler": "^4.0.0"
  }
}
